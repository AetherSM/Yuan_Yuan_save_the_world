<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.RoleApplicationMapper">

    <resultMap id="BaseResultMap" type="com.example.demo.pojo.entity.RoleApplication">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="current_type" property="currentType"/>
        <result column="target_type" property="targetType"/>
        <result column="reason" property="reason"/>
        <result column="status" property="status"/>
        <result column="handler_id" property="handlerId"/>
        <result column="handle_remark" property="handleRemark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        insert into role_applications(
            user_id, current_type, target_type, reason, status,
            create_time, update_time
        ) values (
            #{userId}, #{currentType}, #{targetType}, #{reason}, #{status},
            now(), now()
        )
    </insert>

    <select id="findById" resultMap="BaseResultMap">
        select * from role_applications where id = #{id}
    </select>

    <select id="listByUser" resultMap="BaseResultMap">
        select * from role_applications
        where user_id = #{userId}
        order by create_time desc
    </select>

    <select id="search" resultMap="BaseResultMap">
        select * from role_applications
        <where>
            <if test="userId != null">
                and user_id = #{userId}
            </if>
            <if test="targetType != null">
                and target_type = #{targetType}
            </if>
            <if test="status != null">
                and status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <update id="updateStatus">
        update role_applications
        set status = #{status},
            handler_id = #{handlerId},
            handle_remark = #{handleRemark},
            update_time = now()
        where id = #{id}
    </update>
</mapper>

